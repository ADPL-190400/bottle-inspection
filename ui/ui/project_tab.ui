/* ── Global ── */
QWidget {
    background-color: #F7F8FA;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;

    color: #1A202C;
}

/* ── GroupBox ── */
QGroupBox {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    margin-top: 16px;
    padding: 12px 10px 10px 10px;

    font-weight: bold;
    color: #4A5568;
    letter-spacing: 0.5px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    left: 12px;
    color: #4A5568;

    font-weight: bold;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* ── Labels ── */
QLabel {
    background-color: transparent;
    color: #4A5568;

}
QLabel#label_4 {

    font-weight: bold;
    color: #2D3748;
    min-width: 130px;
}

/* ── ListView ── */
QListView {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;

    color: #1A202C;
    outline: none;
}
QListView::item {
    padding: 8px 12px;
    border-radius: 4px;
}
QListView::item:selected {
    background-color: #EBF4FF;
    color: #2563EB;
}
QListView::item:hover {
    background-color: #F7FAFC;
}

/* ── LineEdit ── */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E0;
    border-radius: 6px;
    padding: 7px 12px;

    color: #1A202C;
    min-height: 34px;
    selection-background-color: #EBF4FF;
}
QLineEdit:focus { border-color: #2563EB; }
QLineEdit:disabled {
    background-color: #EDF2F7;
    color: #A0AEC0;
}

/* ── ComboBox ── */
QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E0;
    border-radius: 6px;
    padding: 6px 12px;

    min-height: 34px;
}
QComboBox:hover { border-color: #2563EB; }

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    selection-background-color: #EBF4FF;
    selection-color: #2563EB;
    padding: 4px;
}

/* ── RadioButton ── */
QRadioButton {

    color: #4A5568;
    spacing: 8px;
}
QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border: 2px solid #CBD5E0;
    background-color: #FFFFFF;
}
QRadioButton::indicator:checked {
    border-color: #2563EB;
    background-color: #2563EB;
}

/* ── SpinBox ── */
QSpinBox {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E0;
    border-radius: 6px;
    padding: 5px 8px;

    min-height: 32px;
}
QSpinBox:focus { border-color: #2563EB; }
QSpinBox::up-button, QSpinBox::down-button {
    width: 20px;

}



/* ── ToolBox ── */
QToolBox::tab {
    background-color: #EDF2F7;
    color: #2D3748;

    font-weight: bold;
    border: 1px solid #E2E8F0;
    border-radius: 4px;
    padding: 66px 10px;
}
QToolBox::tab:selected {
    background-color: #EBF4FF;
    color: #2563EB;
    border-color: #BEE3F8;
}

/* ── Camera frame ── */
QLabel#img_cam {
    background-color: #1A202C;
    border: 1px solid #2D3748;
    border-radius: 6px;
    color: #4A5568;

}

/* ── Buttons ── */
QPushButton#btn_add_project {
    background-color: #FFFFFF;
    color: #2563EB;

    font-weight: bold;
    border: 1px solid #BEE3F8;
    border-radius: 6px;
    padding: 7px 16px;
    min-height: 34px;
}
QPushButton#btn_add_project:hover {
    background-color: #EBF4FF;
    border-color: #90CDF4;
}
QPushButton#btn_add_project:pressed { background-color: #BEE3F8; }

QPushButton#btn_create_project {
    background-color: #2563EB;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 6px;
    padding: 7px 20px;
    min-height: 34px;
}
QPushButton#btn_create_project:hover { background-color: #1D4ED8; }
QPushButton#btn_create_project:pressed { background-color: #1E40AF; }
QPushButton#btn_create_project:disabled {
    background-color: #BEE3F8;
    color: #90CDF4;
}

QPushButton#btn_delete_project {
    background-color: #2563EB;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 6px;
    padding: 7px 20px;
    min-height: 34px;
}
QPushButton#btn_delete_project:hover { background-color: #1D4ED8; }
QPushButton#btn_delete_project:pressed { background-color: #1E40AF; }


QPushButton#btn_execute_trigger {
    background-color: #D97706;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 6px;
    padding: 7px 16px;
    min-height: 34px;
}
QPushButton#btn_execute_trigger:hover { background-color: #B45309; }
QPushButton#btn_execute_trigger:pressed { background-color: #92400E; }

QPushButton#btn_save_camera_config {
    background-color: #38A169;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 7px;
    padding: 10px 28px;
    min-height: 42px;
}
QPushButton#btn_save_camera_config:hover { background-color: #2F855A; }
QPushButton#btn_save_camera_config:pressed { background-color: #276749; }
