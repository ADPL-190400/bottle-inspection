   <string notr="true">
/* ── Global ── */
QWidget {
    background-color: #F7F8FA;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;

    color: #1A202C;
}

/* ── Toolbar row ── */
QWidget#toolbarRow {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E2E8F0;
    min-height: 64px;
    max-height: 64px;
}

/* ── Labels ── */
QLabel {
    background-color: transparent;
    color: #4A5568;
}

/* ── ComboBox ── */
QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E0;
    border-radius: 6px;
    padding: 6px 12px;
    color: #1A202C;
    min-height: 36px;
    selection-background-color: #EBF4FF;
}
QComboBox:hover { border-color: #2563EB; }

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    selection-background-color: #EBF4FF;
    selection-color: #2563EB;
    padding: 4px;
}

/* ── Play button ── */
QPushButton#btn_play {
    background-color: #38A169;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 7px;
    padding: 0px 28px;
    min-height: 42px;
    min-width: 130px;
    max-width: 130px;
}
QPushButton#btn_play:hover { background-color: #2F855A; }
QPushButton#btn_play:pressed { background-color: #276749; }

/* ── Stop button ── */
QPushButton#btn_stop {
    background-color: #FFFFFF;
    color: #E53E3E;

    font-weight: bold;
    border: 2px solid #FC8181;
    border-radius: 7px;
    padding: 0px 28px;
    min-height: 42px;
    min-width: 130px;
    max-width: 130px;
}
QPushButton#btn_stop:hover {
    background-color: #FFF5F5;
    border-color: #E53E3E;
}
QPushButton#btn_stop:pressed {
    background-color: #FED7D7;
}

/* ── Camera frames ── */
QFrame#frame_1, QFrame#frame_2, QFrame#frame_3, QFrame#frame_4, QFrame#frame_5 {
    background-color: #1A202C;
    border: 1px solid #2D3748;
    border-radius: 6px;
}
QLabel#cam_1, QLabel#cam_2, QLabel#cam_3, QLabel#cam_4, QLabel#cam_5 {
    color: #4A5568;

    background-color: transparent;
}

/* ── Result panel ── */
QFrame#frame_6 {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
}
QLabel#text_result {
    background-color: transparent;
    color: #1A202C;

    font-weight: bold;
    border: none;
}
