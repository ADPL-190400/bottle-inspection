   <string notr="true">
/* ── Global ── */
QWidget {
    background-color: #F7F8FA;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;

    color: #1A202C;
}

/* ── GroupBox ── */
QGroupBox {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    margin-top: 16px;
    padding: 12px 10px 10px 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 10px;
    color: #4A5568;

    font-weight: bold;
    letter-spacing: 1px;
}

/* ── Labels ── */
QLabel {
    background-color: transparent;
    color: #4A5568;

}

/* ── ComboBox ── */
QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E0;
    border-radius: 6px;
    padding: 6px 12px;

    min-height: 34px;
}
QComboBox:hover { border-color: #2563EB; }
QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    selection-background-color: #EBF4FF;
    selection-color: #2563EB;
    padding: 4px;
}

/* ── TreeView ── */
QTreeView {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;

    color: #1A202C;
    outline: none;
    alternate-background-color: #F7FAFC;
}
QTreeView::item {
    padding: 5px 8px;
}
QTreeView::item:selected {
    background-color: #EBF4FF;
    color: #2563EB;
}
QTreeView::item:hover {
    background-color: #F7FAFC;
}
QTreeView::branch:selected {
    background-color: #EBF4FF;
}
QHeaderView::section {
    background-color: #EDF2F7;
    border: none;
    border-right: 1px solid #E2E8F0;
    border-bottom: 1px solid #E2E8F0;
    padding: 6px 10px;

    font-weight: bold;
    color: #4A5568;
}

/* ── Image label ── */
ClickableLabel, QLabel#img_show {
    background-color: #1A202C;
    border: 1px solid #2D3748;
    border-radius: 6px;
    color: #4A5568;

}

/* ── Buttons: Start (green) ── */
QPushButton#btn_start_get_data {
    background-color: #38A169;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 7px;
    padding: 0 20px;
    min-height: 44px;
    min-width: 120px;
    max-width: 120px;
}
QPushButton#btn_start_get_data:hover { background-color: #2F855A; }
QPushButton#btn_start_get_data:pressed { background-color: #276749; }

/* ── Buttons: Stop (red outline) ── */
QPushButton#btn_stop_get_data {
    background-color: #FFFFFF;
    color: #E53E3E;

    font-weight: bold;
    border: 2px solid #FC8181;
    border-radius: 7px;
    padding: 0 20px;
    min-height: 44px;
    min-width: 120px;
    max-width: 120px;
}
QPushButton#btn_stop_get_data:hover {
    background-color: #FFF5F5;
    border-color: #E53E3E;
}
QPushButton#btn_stop_get_data:pressed { background-color: #FED7D7; }

/* ── Buttons: Select (amber) ── */
QPushButton#btn_select_template {
    background-color: #D97706;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 7px;
    padding: 0 20px;
    min-height: 44px;
    min-width: 120px;
    max-width: 120px;
}
QPushButton#btn_select_template:hover { background-color: #B45309; }
QPushButton#btn_select_template:pressed { background-color: #92400E; }

/* ── Buttons: Cancel (red outline) ── */
QPushButton#btn_cancle_select {
    background-color: #FFFFFF;
    color: #E53E3E;

    font-weight: bold;
    border: 2px solid #FC8181;
    border-radius: 7px;
    padding: 0 20px;
    min-height: 44px;
    min-width: 120px;
    max-width: 120px;
}
QPushButton#btn_cancle_select:hover {
    background-color: #FFF5F5;
    border-color: #E53E3E;
}
QPushButton#btn_cancle_select:pressed { background-color: #FED7D7; }

/* ── Buttons: Blue (Setup liquid, Export) ── */
QPushButton#btn_setup_liquid, QPushButton#build_memory_bank {
    background-color: #2563EB;
    color: #FFFFFF;

    font-weight: bold;
    border: none;
    border-radius: 7px;
    padding: 0 20px;
    min-height: 44px;
    min-width: 120px;
    max-width: 180px;
}
QPushButton#btn_setup_liquid:hover, QPushButton#build_memory_bank:hover {
    background-color: #1D4ED8;
}
QPushButton#btn_setup_liquid:pressed, QPushButton#build_memory_bank:pressed {
    background-color: #1E40AF;
}
