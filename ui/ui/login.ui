                 <property name="styleSheet">
                  <string notr="true">QToolButton {
    /* Kích thước nhỏ gọn */
    border-radius: 12px; /* 24 / 2 */
    min-width: 24px;
    max-width: 24px;
    min-height: 24px;
    max-height: 24px;

    /* Màu sắc đơn giản: Xám mờ */
    background-color: transparent;
    border: none;
    icon-size: 16px; 
}

/* Khi di chuột: Hiện nền xám nhạt để người dùng biết là nút bấm được */
QToolButton:hover {
    background-color: rgba(0, 0, 0, 10%); /* Đen mờ 10% hoặc dùng #e0e0e0 */
}

/* Khi nhấn: Màu xanh dương dịu để xác nhận */
QToolButton:pressed {
    background-color: rgba(0, 120, 215, 20%);
}

/* Khi ở trạng thái kích hoạt (Show password) */
QToolButton:checked {
    color: #0078d7; /* Đổi màu icon sang xanh nếu dùng font icon */
}</string>
