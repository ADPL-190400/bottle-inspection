   <string notr="true">
QMainWindow{
	
	border-image: url(ui/static/img/login.jpg);
	
}

#widget{
	background-color:#fff;
	border-radius: 5px;
}

Qlabel{
	color:#767e89;
}

Qlabel#label{
color:#000;
}

QLineEdit{
	border:none;
	border-bottom:2px solid#cccccc;
}

QLineEdit:focus{
	border-bottom:2px solid#28a2a2;
}

QPushButton{
	background-color:#0d6efd;
	border: 2px solid #fff;
	color: #fff;
	border-radius: 5px;
	padding: 6px;
}

QPushButton:hover,
QPushButton:clicked{
	background-color:#0b5ed7;
	border: 2px solid #9ac3fe;


}










</string>
