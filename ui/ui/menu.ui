/* ── Global ── */
QMainWindow, QWidget {
    background-color: #F7F8FA;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;

    color: #1A202C;
}

/* ── MenuBar ── */
QMenuBar {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E2E8F0;
    padding: 2px 8px;

    color: #4A5568;
}
QMenuBar::item:selected {
    background-color: #EBF4FF;
    color: #2563EB;
    border-radius: 4px;
}
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    padding: 4px;
}
QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
    color: #1A202C;
}
QMenu::item:selected {
    background-color: #EBF4FF;
    color: #2563EB;
}

/* ── TabWidget ── */
QTabWidget::pane {
    background-color: #F7F8FA;
    border: none;
    border-top: 2px solid #E2E8F0;
}
QTabBar::tab {
    background-color: #FFFFFF;
    color: #718096;
    border: 1px solid #E2E8F0;
    border-bottom: none;
    padding: 10px 28px;

    font-weight: bold;
    min-width: 120px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background-color: #F7F8FA;
    color: #2563EB;
    border-top: 2px solid #2563EB;
    border-bottom: none;
}
QTabBar::tab:hover:!selected {
    background-color: #EBF4FF;
    color: #2563EB;
}

/* ── Section labels ── */
QLabel#label, QLabel#label_2, QLabel#label_3 {
    color: #2D3748;

    font-weight: bold;
    letter-spacing: 1.5px;
    padding-bottom: 2px;
    border-bottom: 2px solid #E2E8F0;
}

/* ── Tile buttons: inspection (green) ── */
QPushButton#btn_process_page {
    background-color: #FFFFFF;
    color: #1A202C;

    font-weight: bold;
    border: 1px solid #C6F6D5;
    border-left: 4px solid #38A169;
    border-radius: 8px;
    padding: 12px 20px;
    text-align: left;
}
QPushButton#btn_process_page:hover {
    background-color: #F0FFF4;
    border-color: #9AE6B4;
    border-left-color: #38A169;
}
QPushButton#btn_process_page:pressed {
    background-color: #C6F6D5;
}

/* ── Tile buttons: setup (blue) ── */
QPushButton#btn_project_page, QPushButton#btn_get_data {
    background-color: #FFFFFF;
    color: #1A202C;

    font-weight: bold;
    border: 1px solid #BEE3F8;
    border-left: 4px solid #2563EB;
    border-radius: 8px;
    padding: 12px 20px;
    text-align: left;
}
QPushButton#btn_project_page:hover, QPushButton#btn_get_data:hover {
    background-color: #EBF8FF;
    border-color: #90CDF4;
    border-left-color: #2563EB;
}
QPushButton#btn_project_page:pressed, QPushButton#btn_get_data:pressed {
    background-color: #BEE3F8;
}

/* ── Tile buttons: logs (amber) ── */
QPushButton#btn_project_log, QPushButton#btn_system_log {
    background-color: #FFFFFF;
    color: #1A202C;

    font-weight: bold;
    border: 1px solid #FEEBC8;
    border-left: 4px solid #D97706;
    border-radius: 8px;
    padding: 12px 20px;
    text-align: left;
}
QPushButton#btn_project_log:hover, QPushButton#btn_system_log:hover {
    background-color: #FFFBEB;
    border-color: #FBD38D;
    border-left-color: #D97706;
}
QPushButton#btn_project_log:pressed, QPushButton#btn_system_log:pressed {
    background-color: #FEEBC8;
}

/* ── StatusBar ── */
QStatusBar {
    background-color: #FFFFFF;
    border-top: 1px solid #E2E8F0;
    color: #718096;

    padding: 2px 12px;
}
